modules = ["nodejs-18"]

[nix]
packages = ["ffmpeg", "nano", "yt-dlp", "speedtest-cli", "tree"]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Video Downloader Bot"

[[workflows.workflow]]
name = "Telegram Video Downloader Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && node index.js"

[env]
NODE_ENV = "production"

[agent]
expertMode = true

[userenv]

[userenv.shared]
MAX_WORKERS = "15"
MAX_QUEUE_SIZE = "100"
MAX_RETRIES = "5"
TIMEOUT = "30"
PROGRESS_THROTTLE = "3"
STATE_FILE = "bot_state.json"
CLEANUP_DAYS = "7"
ALLOWED_USER_IDS = "1170158500,6185398749,6715073207,7027694923"
