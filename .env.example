# Telegram Bot Token (required)
BOT_TOKEN=your_telegram_bot_token_here

# User Authentication (optional - if empty, allows all)
ALLOWED_USER_IDS=123456789,987654321

# Queue & Workers Configuration
MAX_QUEUE_SIZE=100
MAX_WORKERS=5
MAX_RETRIES=3
TIMEOUT=30

# Storage Configuration
DOWNLOAD_DIR=
CLEANUP_DAYS=7

# Logging Configuration
LOG_LEVEL=info

# State File (where bot state is persisted)
STATE_FILE=bot_state.json

# Progress Update Throttle (seconds)
PROGRESS_THROTTLE=3

# Download speed limit per worker (yt-dlp format: '3M'=3MB/s, '500K'=500KB/s)
# Kosongkan untuk tidak dibatasi. Default: 3M
# Upload kamu 48 Mbit/s (~6 MB/s total). 5 worker × 3M = 15 MB/s download.
# Sesuaikan agar download tidak jauh melebihi kapasitas upload.
DOWNLOAD_SPEED_LIMIT=3M

# Fragment concurrent per download (lebih kecil = lebih hemat bandwidth/koneksi)
DOWNLOAD_CONCURRENT_FRAGMENTS=8
